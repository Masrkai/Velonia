{
  // ============================================================================
  // SECURITY & PRIVACY
  // ============================================================================
  "security.workspace.trust.untrustedFiles": "open",
  "telemetry.telemetryLevel": "off",
  "redhat.telemetry.enabled": false,
  "aws.telemetry": false,
  "amazonQ.telemetry": false,
  "amazonQ.suppressPrompts": {
    "amazonQChatDisclaimer": true,
  },

  // ============================================================================
  // UPDATES & EXTENSIONS
  // ============================================================================
  "update.mode": "none",
  "extensions.autoUpdate": false,
  "extensions.ignoreRecommendations": true,
  "yaml.extension.recommendations": false,

  // ============================================================================
  // EDITOR - GENERAL
  // ============================================================================
  "editor.minimap.enabled": false,
  "editor.accessibilitySupport": "off",
  "editor.experimentalGpuAcceleration": "off",
  "editor.indentSize": "tabSize",
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.matchBrackets": "never",

  // ============================================================================
  // EDITOR - FONTS
  // ============================================================================
  "editor.fontSize": 14,
  "editor.fontLigatures": true,
  "editor.fontFamily": "'Iosevka Fixed Hv Ex Obl','Symbols Nerd Font',monospace",

  // ============================================================================
  // WORKBENCH - APPEARANCE
  // ============================================================================
  "workbench.colorTheme": "Lukin Theme",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "none",
  "workbench.layoutControl.enabled": false,
  "workbench.navigationControl.enabled": false,
  "workbench.sideBar.location": "right",
  "workbench.colorCustomizations": {},
  "workbench.editorAssociations": {
    "{git,gitlens}:/**/*.{md,csv,svg}": "default",
  },

  // ============================================================================
  // WINDOW
  // ============================================================================
  "window.titleBarStyle": "native",
  "window.commandCenter": false,
  "window.zoomLevel": -1,
  "window.newWindowProfile": "Default",

  // ============================================================================
  // DIFF EDITOR
  // ============================================================================
  "diffEditor.ignoreTrimWhitespace": false,

  // ============================================================================
  // TERMINAL
  // ============================================================================
  "terminal.integrated.gpuAcceleration": "off",
  "terminal.integrated.focusAfterRun": "terminal",
  "terminal.integrated.fontFamily": "'Iosevka Fixed Hv Ex Obl', 'Symbols Nerd Font'",
  "terminal.integrated.fontSize": 14,
  "terminal.explorerKind": "external",
  "terminal.sourceControlRepositoriesKind": "external",
  "terminal.integrated.scrollback": 2000,
  "terminal.integrated.hideOnStartup": "whenEmpty",
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.sendKeybindingsToShell": true,
  "terminal.integrated.customGlyphs": true,

  "terminal.integrated.rendererType": "dom",
  "terminal.integrated.cursorBlinking": false,
  "terminal.integrated.smoothScrolling": false,
  "terminal.integrated.enableFileLinks": "off",
  "terminal.integrated.shellIntegration.enabled": false,


  // ============================================================================
  // FILES & EXPLORER
  // ============================================================================
  "files.exclude": {
    "**/.git": false,
  },

  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmPasteNative": false,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb",
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*",
  },

  // ============================================================================
  // GIT
  // ============================================================================
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.replaceTagsWhenPull": true,
  "git.openRepositoryInParentFolders": "never",

  // ============================================================================
  // LANGUAGE: NIX
  // ============================================================================
  "[nix]": {
    "editor.defaultFormatter": "jnoortheen.nix-ide",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.formatOnSave": false
  },

  "nix.serverPath": "nixd",
  "nix.enableLanguageServer": true,
  "nix.serverSettings": {
    "nixd": {
      "formatting": {
        "command": ["alejandra"]
      },
      "diagnostic": {
        "suppress": []
      },
      "options": {
        "enable": true,
        "target": {
          "args": []
        }
      }
    }
  },

  // ============================================================================
  // LANGUAGE: PYTHON
  // ============================================================================

  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": false,
  },

  "editor.codeActionsOnSave": {
    "source.fixAll.ruff": "explicit",
    "source.organizeImports.ruff": "explicit",
  },

  "ruff.nativeServer": "on",
  "ruff.trace.server": "off",
  "ruff.path": ["/run/current-system/sw/bin/ruff"],

  "basedpyright.disableOrganizeImports": true,
  "basedpyright.disableLanguageServices": false,
  "basedpyright.analysis.autoSearchPaths": true,
  "basedpyright.analysis.useLibraryCodeForTypes": true,

  "python.terminal.launchArgs": [],
  "python.terminal.focusAfterLaunch": true,
  "python.terminal.activateEnvironment": false,
  "python.createEnvironment.contentButton": "show",

  "python.languageServer": "None",
  "python.defaultInterpreterPath": "/run/current-system/sw/bin/python",

  // TELEMTRY
  "python.experiments.enabled": false,
  "python.diagnostics.sourceMapsEnabled": false,

  // ============================================================================
  // LANGUAGE: Zig
  // ============================================================================
  "[zig]": {
    "editor.defaultFormatter": "ziglang.vscode-zig",
    "editor.formatOnSave": false,
  },

  "zig.path": "/run/current-system/sw/bin/zig",

  "zig.zls.enabled": "on",
  "zig.zls.path": "/run/current-system/sw/bin/zls",
  "zig.buildOnSaveProvider": "off",

  // ============================================================================
  // LANGUAGE: GO
  // ============================================================================
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
    },
  },

  "go.useLanguageServer": true,

  "gopls": {
    "formatting.gofumpt": true,

    "staticcheck": true,

    "analyses": {
      "unusedparams": true,
      "unusedwrite": true,
      "nilness": true,
      "shadow": true,
    },

    "usePlaceholders": true,
    "completeUnimported": true,
  },

  // ============================================================================
  // LANGUAGE: C/C++
  // ============================================================================
  "clangd.arguments": ["--compile-commands-dir=${workspaceFolder}"],

  // ============================================================================
  // LANGUAGE: RUST
  // ============================================================================
  "rust-analyzer.restartServerOnConfigChange": true,
  "rust-analyzer.trace.server": "verbose",

  // ============================================================================
  // LANGUAGE: DART
  // ============================================================================
  "dart.enableServerSnippets": false,

  // ============================================================================
  // LANGUAGE: Slint
  // ============================================================================
  "[slint]": {
    "editor.defaultFormatter": "Slint.slint",
    "editor.formatOnSave": false,
  },

  "slint.lspBinaryPath": "/run/current-system/sw/bin/slint-lsp",
  "slint.preview.style": "native",

  // ============================================================================
  // LANGUAGE: Prolog
  // ============================================================================
  "[prolog]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.formatOnSave": false
  },

  "prolog.executablePath": "/run/current-system/sw/bin/swipl",
  "prolog.dialect": "swi",
  "prolog.terminal.runtimeArgs": [],
  "prolog.linter.run": "onType",
  "prolog.linter.delay": 500,
  "prolog.linter.enableMsgInOutput": true,
  "prolog.format.enabled": true,
  "prolog.format.tabSize": 4,
  "prolog.format.insertSpaces": true,

  // ============================================================================
  // LANGUAGE: PlantUML
  // ============================================================================
  "plantuml.java": "",
  "plantuml.jar": "/run/current-system/sw/lib/plantuml.jar",
  "plantuml.render": "Local",
  "plantuml.urlFormat": "svg",
  "plantuml.exportFormat": "svg",

  // ============================================================================
  // LANGUAGE: Markdown
  // ============================================================================

  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "editor.formatOnSave": true,
  },
  "markdown-preview-enhanced.plantumlJarPath": "/run/current-system/sw/lib/plantuml.jar",
  "markdown-preview-enhanced.chromePath": "/run/current-system/sw/bin/brave",
  "markdown-preview-enhanced.codeBlockTheme": "dark.css",
  "markdown-preview-enhanced.enableCriticMarkupSyntax": true,
  "markdown-preview-enhanced.enableExtendedTableSyntax": true,
  "markdown-preview-enhanced.mermaidTheme": "dark",
  "markdown-preview-enhanced.previewColorScheme": "systemColorScheme",
  "markdown-preview-enhanced.revealjsTheme": "black.css",
  "markdown-preview-enhanced.previewTheme": "atom-dark.css",
  "markdown-preview-enhanced.usePandocParser": true,
  "markdown-preview-enhanced.latexEngine": "xelatex",
  "markdown-preview-enhanced.mathRenderingOption": "MathJax",

  // ============================================================================
  // LANGUAGE: JSON
  // ============================================================================
  "json.schemaDownload.enable": false,

  // ============================================================================
  // EXTENSION: CODE RUNNER
  // ============================================================================
  "code-runner.runInTerminal": true,
  "code-runner.enableAppInsights": false,
  "code-runner.executorMap": {
    "php": "php",
    "lua": "lua",
    "v": "v run",
    "perl": "perl",
    "ruby": "ruby",
    "go": "go run",
    "r": "Rscript",
    "dart": "dart",
    "bat": "cmd /c",
    "fsharp": "fsi",
    "zig": "zig run",
    "perl6": "perl6",
    "scala": "scala",
    "swift": "swift",
    "julia": "julia",
    "ocaml": "ocaml",
    "groovy": "groovy",
    "racket": "racket",
    "mojo": "mojo run",
    "ahk": "autohotkey",
    "autoit": "autoit3",
    "haskell": "runghc",
    "kit": "kitc --run",
    "erlang": "escript",
    "javascript": "node",
    "csharp": "scriptcs",
    "crystal": "crystal",
    "spwn": "spwn build",
    "python": "python -u",
    "shellscript": "bash",
    "clojure": "lein exec",
    "typescript": "ts-node",
    "scheme": "csi -script",
    "lisp": "sbcl --script",
    "coffeescript": "coffee",
    "applescript": "osascript",
    "vbscript": "cscript //Nologo",
    "sass": "sass --style expanded",
    "scss": "scss --style expanded",
    "sml": "cd $dir && sml $fileName",
    "gleam": "gleam run -m $fileNameWithoutExt",
    "nim": "nim compile --verbosity:0 --hints:off --run",
    "powershell": "powershell -ExecutionPolicy ByPass -File",
    "d": "cd $dir && dmd $fileName && $dir$fileNameWithoutExt",
    "less": "cd $dir && lessc $fileName $fileNameWithoutExt.css",
    "rust": "cd $dir && rustc $fileName && $dir$fileNameWithoutExt",
    "pascal": "cd $dir && fpc $fileName && $dir$fileNameWithoutExt",
    "java": "cd $dir && javac $fileName && java $fileNameWithoutExt",
    "haxe": "haxe --cwd $dirWithoutTrailingSlash --run $fileNameWithoutExt",
    "pkl": "cd $dir && pkl eval -f yaml $fileName -o $fileNameWithoutExt.yaml",
    "c": "cd $dir && gcc $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "cpp": "cd $dir && clear && g++ $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "fortran": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "fortran-modern": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "FortranFreeForm": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "fortran_fixed-form": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "objective-c": "cd $dir && gcc -framework Cocoa $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
  },

  // ============================================================================
  // EXTENSION: BETTER COMMENTS
  // ============================================================================
  "better-comments.tags": [
    {
      "tag": "!",
      "color": "#FF2D00",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
    {
      "tag": "?",
      "color": "#3498DB",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
    {
      "tag": "todo",
      "color": "#FF8C00",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
    {
      "tag": "*",
      "color": "#98C379",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
    {
      "tag": ">",
      "color": "#F4CE14",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
    {
      "tag": "-",
      "color": "#8C6A5D",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false,
    },
  ],

  // ============================================================================
  // EXTENSION: JUPYTER
  // ============================================================================
  "jupyter.askForKernelRestart": false,

  // ============================================================================
  // EXTENSION: NOTEBOOK
  // ============================================================================
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left",
  },
  "notebook.output.wordWrap": true,
  "notebook.output.textLineLimit": 600,
  "notebook.output.minimalErrorRendering": true,
  "notebook.output.scrolling": true,

  // ============================================================================
  // EXTENSION: SQLITE3 EDITOR
  // ============================================================================
  "sqlite3-editor.ui.minimizePanel": true,

  // ============================================================================
  // EXTENSION: BASH IDE
  // ============================================================================
  "bashIde.explainshellEndpoint": "http://localhost:5000",

  // ============================================================================
  // EXTENSION: Cmake Tools
  // ============================================================================
  "cmake.enableAutomaticKitScan": false,
  "cmake.automaticReconfigure": false,
  "cmake.autoSelectActiveFolder": false,
  "cmake.configureOnOpen": false,
  "cmake.configureOnEdit": false,
  "cmake.ctest.testExplorerIntegrationEnabled": false,


  // ============================================================================
  // EXTENSION: LIVE SERVER
  // ============================================================================
  "liveServer.settings.donotShowInfoMsg": true,

  // ============================================================================
  // EXTENSION: DRAWIO
  // ============================================================================
  "hediet.vscode-drawio.resizeImages": null,

  // ============================================================================
  // LAUNCH CONFIGURATION
  // ============================================================================
  "launch": {
    "configurations": [],
    "compounds": [],
  },

  // ============================================================================
  // SPELL CHECKER
  // ============================================================================

  "typos.logLevel": "warn",
  "typos.diagnosticSeverity": "Hint",
  "typos.path": "/run/current-system/sw/bin/typos-lsp",

}
